{
  "id": "ecommerce-realm",
  "realm": "ecommerce-realm",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "clients": [
    {
      "clientId": "api-gateway-client",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": ["*"],
      "webOrigins": ["*"],
      "protocol": "openid-connect"
    }
  ],
  "users": [
    {
      "username": "testuser",
      "enabled": true,
      "emailVerified": true,
      "email": "testuser@ecommerce.local",
      "firstName": "Test",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "password",
          "temporary": false
        }
      ],
      "realmRoles": ["CUSTOMER"]
    }
  ],
  "roles": {
    "realm": [
      {
        "name": "CUSTOMER",
        "description": "Standard customer who can place and view orders"
      }
    ]
  }
}
